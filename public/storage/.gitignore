# Allow all files in this directory
!*
!.gitignore

# gallery/ and media/ are symlinks → storage/app/uploads/ (persistent, survives deploys)
# The symlink targets are auto-created by AppServiceProvider on every boot.
# We do NOT ignore the symlinks themselves — they should be recreated by the OS if wiped.
# The actual uploaded files live in storage/app/uploads/ which is outside git scope.

# Exclude large zip files to keep git light
*.zip
*.tar.gz
*.rar
