################################
# PRODUCTION ENVIRONMENT
# Copy to .env dan isi dengan nilai production
################################

# Application
APP_NAME=medantobatravel
APP_ENV=production
APP_KEY=base64:generate_with_artisan_key_generate   # Generate: php artisan key:generate
APP_DEBUG=false                             # HARUS false di production!
APP_URL=https://www.medantobatravel.com      # Ganti dengan domain production Anda

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

# Database (MySQL/PostgreSQL)
DB_CONNECTION=mysql
DB_HOST=your_db_host_here
DB_PORT=3306
DB_DATABASE=your_db_name_here
DB_USERNAME=your_db_username_here
DB_PASSWORD=your_db_password_here        # Password yang sangat kuat!

# Session
SESSION_DRIVER=database                     # Gunakan database untuk session production
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.medantobatravel.com

# Cache
CACHE_STORE=redis                           # Atau database/file
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# Queue
QUEUE_CONNECTION=database                   # Atau redis

# Filesystem
FILESYSTEM_DISK=local
# Untuk public uploads:
FILESYSTEM_PUBLIC_DRIVER=public

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Mail (SMTP)
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=mail.domain.com
MAIL_PORT=587
MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM_ADDRESS=noreply@medantobatravel.com
MAIL_FROM_NAME="Sujai Laketoba"

# Security Headers
APP_TRUST_PROXIES=*
APP_TRUST_HOST_PATTERNS=

# Sanctum API
SANCTUM_STATEFUL_DOMAINS=medantobatravel.com
SANCTUM_ENCRYPT_COOKIES=true

# Broadcasting (jika perlu)
BROADCAST_CONNECTION=log
# Untuk production, bisa gunakan Pusher/Socket.io

# AWS S3 (jika upload ke S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# Sentry (Error tracking - optional)
# SENTRY_LARAVEL_DSN=https://xxx@sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# Vite (Asset URLs)
VITE_APP_NAME="${APP_NAME}"

# Timezone
APP_TIMEZONE=Asia/Jakarta
